<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Caerlangs_calculator" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Caerlangs_calculator" parent="Base.Theme.Caerlangs_calculator" />

    <style name="CircleButton">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.App.CalculatorButton.Number" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">#1C1C1E</item>
        <item name="shapeAppearanceOverlay">@style/CircleButton</item>
    </style>

    <style name="Widget.App.CalculatorButton.Operator" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textColor">#2FD158</item>
        <item name="backgroundTint">#2C2C2E</item>
        <item name="shapeAppearanceOverlay">@style/CircleButton</item>
    </style>

    <style name="Widget.App.CalculatorButton.Clear" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textColor">#FF4444</item>
        <item name="backgroundTint">#2C2C2E</item>
        <item name="shapeAppearanceOverlay">@style/CircleButton</item>
    </style>

    <style name="Widget.App.CalculatorButton.Equal" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textColor">#000000</item>
        <item name="backgroundTint">#2FD158</item>
        <item name="shapeAppearanceOverlay">@style/CircleButton</item>
    </style>


</resources>