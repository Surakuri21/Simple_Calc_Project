<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Display Area -->

    <!-- Button Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:layout_weight="0"
        android:gravity="bottom|end"
        android:orientation="vertical"
        android:paddingBottom="24dp"
         >

        <TextView
            android:id="@+id/tvHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#7F7F7F"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="60sp"
            android:textStyle="bold" />
    </LinearLayout>

    <GridLayout
        android:layout_width="371dp"
        android:layout_height="505dp"
        android:alignmentMode="alignMargins"
        android:columnCount="4"
        android:rowCount="5">

        <!-- Row 1: Clear, Brackets, Percent, Divide -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnC"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="88.75dp"
            android:layout_height="100dp"
            android:text="C"
            android:textColor="#FF4444"
            app:backgroundTint="#2C2C2E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"

            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBrackets"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="88.75dp"
            android:layout_height="100dp"
            android:text="( )"
            android:textColor="#2FD158"
            app:backgroundTint="#2C2C2E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"

            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPercent"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="88.75dp"
            android:layout_height="100dp"
            android:text="%"
            android:textColor="#2FD158"
            app:backgroundTint="#2C2C2E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDiv"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="88.75dp"
            android:layout_height="100dp"
            android:text="÷"
            android:textColor="#2FD158"
            app:backgroundTint="#2C2C2E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <!-- Row 2: 7, 8, 9, Multiply -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn7"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="88dp"
            android:layout_height="100dp"
            android:text="7"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn8"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="8"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn9"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="9"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMul"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="×"
            android:textColor="#2FD158"
            app:backgroundTint="#2C2C2E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <!-- Row 3: 4, 5, 6, Subtract -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn4"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="88.75dp"
            android:layout_height="100dp"
            android:text="4"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn5"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="5"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn6"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="6"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSub"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="-"
            android:textColor="#2FD158"
            app:backgroundTint="#2C2C2E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <!-- Row 4: 1, 2, 3, Add -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn1"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="88.75dp"
            android:layout_height="100dp"
            android:text="1"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn2"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="2"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn3"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="3"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdd"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="+"
            android:textColor="#2FD158"
            app:backgroundTint="#2C2C2E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <!-- Row 5: Plus/Minus, 0, Dot, Equal -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlusMinus"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="88.75dp"
            android:layout_height="100dp"
            android:text="+/-"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn0"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="0"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDot"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="."
            android:textColor="#FFFFFF"
            app:backgroundTint="#1C1C1E"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEqual"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="91dp"
            android:layout_height="100dp"
            android:text="="
            android:textColor="#000000"
            app:backgroundTint="#2FD158"
            app:shapeAppearanceOverlay="@style/CircleButton"
            android:layout_margin="4dp"
            />

    </GridLayout>
</LinearLayout>